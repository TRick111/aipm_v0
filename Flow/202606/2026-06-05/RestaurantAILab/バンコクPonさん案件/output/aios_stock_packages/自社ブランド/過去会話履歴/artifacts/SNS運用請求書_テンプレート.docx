from docx import Document

# 請求書テンプレート作成
doc = Document()

doc.add_heading('請求書 / Invoice', level=1)

# 発行日と請求番号
doc.add_paragraph('発行日: 2025年8月12日')
doc.add_paragraph('請求書番号: 2025-001')

# 請求先
doc.add_heading('請求先 / Bill To:', level=2)
doc.add_paragraph('〇〇株式会社')
doc.add_paragraph('〒000-0000 東京都〇〇区〇〇 0-0-0')
doc.add_paragraph('担当: 〇〇 様')

# 請求元
doc.add_heading('請求元 / From:', level=2)
doc.add_paragraph('Your Company Co., Ltd.')
doc.add_paragraph('123 Sukhumvit 57, Bangkok, Thailand')
doc.add_paragraph('TEL: +66-XX-XXXX-XXXX')
doc.add_paragraph('担当: PON KONDO')

# 請求内容
doc.add_heading('請求内容 / Description', level=2)
table = doc.add_table(rows=1, cols=4)
hdr_cells = table.rows[0].cells
hdr_cells[0].text = '項目 / Item'
hdr_cells[1].text = '数量 / Qty'
hdr_cells[2].text = '単価 / Unit Price (JPY)'
hdr_cells[3].text = '金額 / Amount (JPY)'

row_cells = table.add_row().cells
row_cells[0].text = 'SNS運用代行サービス'
row_cells[1].text = '1'
row_cells[2].text = '100,000'
row_cells[3].text = '100,000'

# 合計
doc.add_paragraph('小計 / Subtotal: 100,000 JPY')
doc.add_paragraph('消費税 / Consumption Tax (Japan): 非課税 / Not subject to Japanese Consumption Tax')
doc.add_paragraph('合計 / Total: 100,000 JPY')

# 備考
doc.add_heading('備考 / Notes', level=2)
doc.add_paragraph(
    '本業務は国外（タイ）において提供された役務であり、日本の消費税の課税対象外です。'
)
doc.add_paragraph(
    'This service was provided outside Japan (in Thailand) and is not subject to Japanese consumption tax.'
)

# 保存
file_path = '/mnt/data/SNS運用請求書_タイ法人-日本企業向け.docx'
doc.save(file_path)

file_path