      "lines[*].code": "東京メトロ路線記号 (G/M/Mb/H/T/C/Y/Z/N/F)",
      "lines[*].name_ja": "路線の日本語名",
      "lines[*].name_en": "Line name in English",
      "lines[*].stations[*].station_code": "駅ナンバリング (例: G01)",
      "lines[*].stations[*].kanji": "漢字表記",
      "lines[*].stations[*].hiragana": "ひらがな表記",
      "lines[*].stations[*].char_count": "ひらがな文字数",
      "unique_stations[*].kanji": "漢字表記",
      "unique_stations[*].hiragana": "ひらがな表記",
      "unique_stations[*].char_count": "ひらがな文字数",
      "unique_stations[*].lines": "停車する路線記号の配列"
    }
  },
