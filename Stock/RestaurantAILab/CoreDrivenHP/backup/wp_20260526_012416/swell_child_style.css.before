  width: 3rem;
  height: 3rem;
  background: #3b82f6;
  color: white;
  border-radius: 0.5rem;
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-align: center;
      -ms-flex-align: center;
          align-items: center;
  -webkit-box-pack: center;
      -ms-flex-pack: center;
          justify-content: center;
  margin-bottom: 1rem;
}

.feature-card h4 {
  font-size: 1.125rem;
  font-weight: bold;
  margin-bottom: 0.75rem;
}

.feature-card p {
  font-size: 0.875rem;
  color: #4a5568;
  line-height: 1.6;
}

