  z-index: 10;
}

.title-section .background-text {
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
          transform: translate(-50%, -50%);
  font-size: 3.75rem;
  font-weight: 700;
  color: #f9fafb;
  white-space: nowrap;
  z-index: 0;
}

/* Base styles */
.biz__container {
  min-height: 100vh;
  background-color: #f3f4f6;
}

.biz__card {
  position: relative;
  min-height: auto;
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-orient: vertical;
  -webkit-box-direction: normal;
      -ms-flex-direction: column;
          flex-direction: column;
}

/* Content section */
.biz__content {
  width: 100%;
  padding: 1rem;
  background: linear-gradient(135deg, #f2fafc 0%, #ddfdff 49%, #b5fbff 100%);
  min-height: auto;
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-orient: vertical;
  -webkit-box-direction: normal;
      -ms-flex-direction: column;
          flex-direction: column;
  -webkit-box-pack: center;
      -ms-flex-pack: center;
          justify-content: center;
  opacity: 0;
  /* 初期値: 非表示 */
  -webkit-transition: opacity 2s ease-in;
  transition: opacity 2s ease-in;
  /* アニメーションをスムーズに */
}

.biz__content.inview {
  opacity: 1;
  /* 表示時: 透明度を1に変更 */
}

.biz__image-wrapper {
  margin-bottom: 2rem;
  /* @apply mb-8 */
  margin-left: auto;
  /* @apply mx-auto */
  margin-right: auto;
  /* @apply flex-[5] */
  max-width: 500px;
  width: 100%;
}

.biz__image {
  width: 100%;
  /* @apply w-full */
  aspect-ratio: 1/1;
  /* @apply aspect-square */
  -o-object-fit: cover;
     object-fit: cover;
  /* @apply object-cover */
  /* @apply rounded-lg */
  -webkit-box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  /* @apply shadow-md */
  max-width: 100%;
}

.biz__image img {
  max-width: 100%;
}

.biz__text {
  max-width: 500px;
  margin-left: auto;
  /* @apply mx-auto */
  margin-right: auto;
  /* @apply mx-auto */
  -webkit-box-flex: 5;
      -ms-flex: 5;
          flex: 5;
  /* @apply flex-[5] */
  width: 100%;
