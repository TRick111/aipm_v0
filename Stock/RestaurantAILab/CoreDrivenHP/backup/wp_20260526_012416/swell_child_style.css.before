/* === BL-0079 / 2026-05-09 修正用 オーバーライド =================
 * 1. AI HTML の Hero/Page Hero の h1 を SWELL post_content デフォルトから救済
 * 2. SWELL の page top title (l-topTitleArea > c-pageTitle) を非表示
 * ============================================================ */
.ai-fullhtml-wrap .hero h1,
.ai-fullhtml-wrap .page-hero h1 {
  font-size: clamp(40px, 6vw, 72px) !important;
  line-height: 1.1 !important;
  letter-spacing: -.035em !important;
  font-weight: 800 !important;
}
@media (max-width: 640px) {
  .ai-fullhtml-wrap .hero h1,
  .ai-fullhtml-wrap .page-hero h1 {
    font-size: 38px !important;
    line-height: 1.12 !important;
  }
}

/* SWELL のページ上部タイトル (l-topTitleArea) を非表示 (田中さん指定セレクタ) */
#main_content > div > h1 > span { display: none !important; }
.l-topTitleArea { display: none !important; }

/* === BL-0079 / 2026-05-09 追加修正: パンくず + 装飾線を非表示 ===
 * 田中さん指示: #main_content > div の中だけ表示すれば良い
 *               パンくずリスト + 横線も削除
 */
.p-breadcrumb,
nav.p-breadcrumb,
.p-breadcrumb__list,
.l-pageBody > nav.p-breadcrumb { display: none !important; }

/* main_content の上にある可能性のある hr / セパレータ */
#main_content + hr,
.l-content > hr,
.l-pageBody > hr,
.l-mainContent::before { display: none !important; }

/* === BL-0079 / 2026-05-09 追加修正 v2: c-pageTitle ごと非表示 ===
 * 直前の修正 (#main_content > div > h1 > span のみ非表示) では h1 本体が残り、
 * その border-bottom が 1px の横線として残存していた → h1 ごと消す
 */
h1.c-pageTitle,
.c-pageTitle,
#main_content > div > h1 { display: none !important; }

/* === BL-0079 / 2026-05-09 追加修正 v3: ヘッダー直下と page-hero の間の隙間を 0 に ===
 * 田中さん指示: ページ上部のグラデ長方形と一番上 (ヘッダー直下) の間の隙間を無くす
 * 構成: #content padding-top:60px + .post_content margin-top:64px = 計 124px
 * 対象: AI HTML を含むページのみ (privacy-policy 等は影響させない)
 * 手段: :has() セレクタで limit
 */
body:has(.ai-fullhtml-wrap) #content,
.l-content:has(.ai-fullhtml-wrap) {
  padding-top: 0 !important;
}
.post_content:has(.ai-fullhtml-wrap) {
  margin-top: 0 !important;
}
/* TOP 専用 SWELL CSS .top #content { padding-top: 4em } も上書き */
body.top #content {
  padding-top: 0 !important;
}


/* === CoreDriven custom HTML pages — SWELL override v2 (2026-05-26) === */
/* Applies to: TOP (10), Biz Core (704), AI Core (706), Contact-new (708), Company-new (710) */
/* Strategy: use :where() so page-id prefixes contribute 0 to specificity. */
/* That keeps these rules at (0,1,1) — same as SWELL's .post_content rules — */
/* so they win over SWELL via source order, but lose to in-page (.fit-card h3, .final-cta p) */
/* which also have (0,1,1) and come later in source as inline body <style>. */

/* Layout — these MUST use !important to override CSS custom properties from SWELL */
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) #content.l-content.l-container {
  padding-left: 0 !important;
  padding-right: 0 !important;
  max-width: 100% !important;
  margin-bottom: 0 !important;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .l-mainContent__inner > .post_content {
  margin: 0 !important;
  padding: 0 !important;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content {
  line-height: 1.7;
  max-width: 100%;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content > * {
  margin-bottom: 0;
  clear: none;
}

/* Type scale — re-instate Core Driven design system at the same specificity as SWELL */
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content h1 {
  font-size: clamp(40px, 6vw, 72px); line-height: 1.1; letter-spacing: -.035em; font-weight: 800; margin: 0;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content h2 {
  font-size: clamp(26px, 3.6vw, 48px); line-height: 1.18; letter-spacing: -.025em; font-weight: 800; margin: 0;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content h3 {
  font-size: clamp(20px, 2vw, 26px); line-height: 1.3; font-weight: 800; margin: 0;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content h4 {
  font-size: 18px; font-weight: 800; margin: 0;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content p { margin: 0; }
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content ul,
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content ol {
  padding-left: 0; list-style: none;
}
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content li {
  margin: 0; line-height: inherit;
}

/* Section heads — let the in-page styles handle the rest */
:where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content .section-head h2 {
  white-space: pre-wrap;
}

/* Mobile tweak — bring h2 down to local design system's mobile size (was 26 → 24) */
@media (max-width: 720px) {
  :where(.page-id-10, .page-id-704, .page-id-706, .page-id-708, .page-id-710) .post_content h2 {
    font-size: 24px; line-height: 1.3;
  }
}
/* === /CoreDriven override v2 === */
