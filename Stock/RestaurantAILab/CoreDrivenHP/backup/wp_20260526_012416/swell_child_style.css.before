/* Layout */
@media (max-width: 480px) {
  .company__container {
    padding: 0 0;
  }
}
.company__container {
  width: 100%;
  margin: 0 auto;
  padding: 0 1rem;
  position: relative;
}

/* Hero Section */
.company__hero {
  position: relative;
  height: 50vh;
  background-color: var(--color-gray-900);
  width: 80%;
  margin: auto;
}

.company__hero-background {
  position: absolute;
  inset: 0;
  width: 100%;
}

.company__hero-image {
  width: 100%;
  height: 100%;
  -o-object-fit: cover;
     object-fit: cover;
  -webkit-filter: grayscale(100%);
          filter: grayscale(100%);
}

.company__hero-overlay {
  position: absolute;
  inset: 0;
  background: -webkit-gradient(linear, left top, right top, from(rgba(255, 255, 255, 0.8)), to(rgba(221, 221, 221, 0.8)));
  background: linear-gradient(to right, rgba(255, 255, 255, 0.8), rgba(221, 221, 221, 0.8));
  mix-blend-mode: multiply;
}

.company__hero-container {
  height: 100%;
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-align: center;
      -ms-flex-align: center;
          align-items: center;
  -webkit-box-pack: center;
      -ms-flex-pack: center;
          justify-content: center;
}

/* Profile Image */
.company__profile-image {
  position: relative;
  width: 20rem;
  height: 25rem;
  border: 4px solid white;
  -webkit-box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
          box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

@media (max-width: 1023px) {
  .company__profile-image {
    position: absolute;
    bottom: 0;
    left: 50%;
    -webkit-transform: translate(-50%, 50%);
            transform: translate(-50%, 50%);
  }
}
.company__profile-image img {
  width: 100%;
  height: 100%;
  -o-object-fit: cover;
     object-fit: cover;
}

/* Icon Images */
.company__icon-image {
  width: 24px;
  height: 24px;
  -o-object-fit: cover;
     object-fit: cover;
  border-radius: 4px;
}

.company__link-icon {
  width: 24px;
  height: 24px;
  -o-object-fit: cover;
     object-fit: cover;
  -webkit-filter: brightness(0) invert(1);
          filter: brightness(0) invert(1);
  opacity: 0;
  -webkit-transform: translateY(0.5rem);
          transform: translateY(0.5rem);
  -webkit-transition: all 0.3s ease;
  transition: all 0.3s ease;
}

/* Main Content */
.company__main {
  width: 100%;
  max-width: 64rem;
  /* 4xl相当 */
  margin: 0 auto;
  padding: 2rem;
}

.company__card {
  background: white;
  border-radius: 1rem;
  -webkit-box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  padding: var(--card-padding);
  margin-top: 6rem;
}

/* Profile */
.company__profile {
  text-align: center;
  margin-bottom: 2rem;
}

@media (max-width: 1023px) {
  .company__profile {
    padding-top: 6rem;
  }
}
.company__profile-name {
  font-size: 1.875rem;
  font-weight: bold;
  margin-bottom: 0.5rem;
}

.company__profile-title {
  color: var(--color-gray-600);
  font-size: 1.125rem;
}

/* Timeline */
.company__section {
  max-width: 42rem;
  margin: 0 auto 3rem;
}

.company__timeline {
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.company__timeline-icon {
  -ms-flex-negative: 0;
      flex-shrink: 0;
  margin-top: 0.25rem;
  color: var(--color-primary);
}

.company__timeline-content {
  -webkit-box-flex: 1;
      -ms-flex: 1;
          flex: 1;
}

.company__timeline-title {
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.company__timeline-list {
  list-style: none;
  margin-top: 0.5rem;
}

.company__timeline-list li {
  margin-bottom: 1rem;
}

.company__timeline-date {
  font-weight: 500;
  display: block;
}

.company__timeline-position {
  color: var(--color-gray-600);
}

/* Book */
.company__book {
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-align: center;
      -ms-flex-align: center;
          align-items: center;
  gap: 1.5rem;
  margin-top: 0.5rem;
  -webkit-box-pack: center;
      -ms-flex-pack: center;
          justify-content: center;
}

.company__book-link {
  display: block;
  position: relative;
}

.company__book-image-container {
  position: relative;
  overflow: hidden;
  border-radius: 0.25rem;
  -webkit-transition: -webkit-transform 0.3s ease;
  transition: -webkit-transform 0.3s ease;
  transition: transform 0.3s ease;
  transition: transform 0.3s ease, -webkit-transform 0.3s ease;
}

.company__book-image-container:hover {
  -webkit-transform: scale(1.05);
          transform: scale(1.05);
}

.company__book-image {
  width: 8rem;
  -webkit-box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  border-radius: 0.25rem;
}

.company__book-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0);
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-align: center;
      -ms-flex-align: center;
          align-items: center;
  -webkit-box-pack: center;
      -ms-flex-pack: center;
          justify-content: center;
  -webkit-transition: background-color 0.3s ease;
  transition: background-color 0.3s ease;
}

.company__book-image-container:hover .company__book-overlay {
  background: rgba(0, 0, 0, 0.1);
}

.company__book-image-container:hover .company__link-icon {
  opacity: 1;
  -webkit-transform: translateY(0);
          transform: translateY(0);
}

.company__book-title {
  color: var(--color-gray-600);
}

/* CTA Button */
.company__cta {
  text-align: center;
}

.company__button {
  display: -webkit-inline-box;
  display: -ms-inline-flexbox;
  display: inline-flex;
  -webkit-box-align: center;
